# Stripe (MUST use test keys — E2E tests validate the pk_test_ / sk_test_ prefix)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SHIPPING_RATE_PRODUCT=shr_...
STRIPE_SHIPPING_RATE_KIT=shr_...

# Chatbot (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Member Auth
JWT_SECRET=change-this-to-a-random-secret-in-production

# Email (Resend)
RESEND_API_KEY=re_...
# Where wholesale inquiry emails are delivered (defaults to Jeff's inbox)
WHOLESALE_EMAIL_TO=jeff.t1.bania@gmail.com
# Verified "from" address in Resend — defaults to Resend's sandbox sender if unset
WHOLESALE_EMAIL_FROM=wholesale@jimmypotters.com

# Site URL
NEXT_PUBLIC_URL=http://localhost:3000

# Supabase (project URL + anon key are safe on the client; service-role key is server-only)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Bulk-order alerts (emailed to Jimmy on orders at/above BULK_NOTIFY_THRESHOLD pots)
BULK_NOTIFY_THRESHOLD=10
JIMMY_NOTIFY_EMAIL=jimmy@jimmypotters.com
CUSTOMER_SERVICE_CC_EMAIL=jeff.t1.bania@gmail.com

# Alternate payment handles (used on the Stripe checkout step)
NEXT_PUBLIC_VENMO_USERNAME=Jimmy-Potters
NEXT_PUBLIC_PAYPAL_ME_USERNAME=JimmyPotters

# Vercel cron auth — set a random string; cron routes accept the bearer token or
# the x-vercel-cron header the Vercel scheduler sends. In production without
# this set, cron routes refuse to run so the endpoint can't be hit anonymously.
CRON_SECRET=change-me-to-a-random-string
